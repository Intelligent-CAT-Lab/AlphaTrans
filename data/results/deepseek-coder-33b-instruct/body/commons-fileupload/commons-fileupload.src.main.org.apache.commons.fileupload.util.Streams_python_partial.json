                        "                    default:\n",
                        "                        sb.append(c);\n",
                        "                        break;\n",
                        "                }\n",
                        "            }\n",
                        "            throw new InvalidFileNameException(fileName, \"Invalid file name: \" + sb);\n",
                        "        }\n",
