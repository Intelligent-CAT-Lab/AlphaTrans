                        "        try (CSVPrinter printer = new CSVPrinter(stringWriter, csvFormat)) {\n",
                        "            printer.print(\"a\");\n",
                        "            printer.printRecord0(Arrays.asList(\"b\", \"c\"));\n",
                        "        }\n",
                        "        assertEquals(\"a,b,c\\r\\n\", stringWriter.toString());\n",
                        "    }\n"
