                        "        String XXXX = \"XXXX\";\n",
                        "        Integer expected = Integer.valueOf(12345);\n",
                        "        assertEquals(\n",
                        "                \"validate(A) default\",\n",
                        "                expected,\n",
                        "                IntegerValidator.getInstance().validate0(defaultVal));\n",
                        "        assertEquals(\n",
                        "                \"validate(A) locale \",\n",
                        "                expected,\n",
                        "                IntegerValidator.getInstance().validate2(localeVal, locale));\n",
                        "        assertEquals(\n",
                        "                \"validate(A) pattern\",\n",
                        "                expected,\n",
