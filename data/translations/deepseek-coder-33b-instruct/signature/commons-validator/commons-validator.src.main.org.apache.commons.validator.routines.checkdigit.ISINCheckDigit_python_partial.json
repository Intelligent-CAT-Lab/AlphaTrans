                        "                        \"Invalid Character[\" + (i + 1) + \"] = '\" + charValue + \"'\");\n",
                        "            }\n",
                        "            transformed.append(charValue);\n",
                        "        }\n",
                        "        return super.calculateModulus(transformed.toString(), includesCheckDigit);\n",
                        "    }\n"
