                        "                throw CheckDigitException.CheckDigitException1(\n",
                        "                        \"Invalid checkdigit[\" + checkDigit + \"] in \" + code);\n",
                        "            }\n",
                        "        }\n",
                        "        for (int i = 0; i < code.length(); i++) {\n",
                        "            int charValue = Character.getNumericValue(code.charAt(i));\n",
