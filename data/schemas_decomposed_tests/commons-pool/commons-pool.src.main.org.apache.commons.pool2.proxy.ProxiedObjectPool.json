                        "        UsageTracking<T> usageTracking = null;\n",
                        "        if (pool instanceof UsageTracking) {\n",
                        "            usageTracking = (UsageTracking<T>) pool;\n",
                        "        }\n",
                        "        return proxySource.createProxy(pool.borrowObject(), usageTracking);\n",
                        "    }\n"
