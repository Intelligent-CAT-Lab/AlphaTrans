                    "body": [
                        "    public static <K, V> Map<K, V> merge(final Map<K, V> lhs, final Map<K, V> rhs) {\n",
                        "        Map<K, V> result = null;\n",
                        "        if (lhs == null || lhs.isEmpty()) {\n",
                        "            result = copy(rhs);\n",
                        "        } else if (rhs == null || rhs.isEmpty()) {\n",
                        "            result = copy(lhs);\n",
                        "        } else {\n",
                        "            result = copy(lhs);\n",
                        "            result.putAll(rhs);\n",
                        "        }\n",
                        "        return result;\n",
                        "    }\n"
                    ],
