                        "        softRef = new SoftReference<>(REFERENT2);\n",
                        "        ref.setReference(softRef);\n",
                        "\n",
                        "        assertEquals(REFERENT2, ref.getObject());\n",
                        "\n",
                        "        softRef = ref.getReference();\n",
                        "        assertEquals(REFERENT2, softRef.get());\n",
                        "        softRef.clear();\n",
                        "    }\n"
                    ],
