                    "body": [
                        "    static String stripLeadingHyphens(final String str) {\n",
                        "        if (str == null) {\n",
                        "            return null;\n",
                        "        }\n",
                        "        if (str.startsWith(\"--\")) {\n",
                        "            return str.substring(2);\n",
                        "        }\n",
                        "        if (str.startsWith(\"-\")) {\n",
                        "            return str.substring(1);\n",
                        "        }\n",
                        "\n",
                        "        return str;\n",
                        "    }\n"
                    ],
