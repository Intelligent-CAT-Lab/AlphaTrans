                        "                                    new BaseWeightedEdge<Double>());\n",
                        "            expected.addConnectionInTail(\n",
                        "                    one, new BaseLabeledWeightedEdge<Double>(\"1 -> 3\", 9D), three);\n",
                        "            expected.addConnectionInTail(\n",
                        "                    three, new BaseLabeledWeightedEdge<Double>(\"3 -> 6\", 2D), six);\n",
                        "\n",
                        "            assertEquals(expected, wp);\n",
