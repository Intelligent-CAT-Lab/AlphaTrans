                        "    private static int hexToBinary(final byte b) throws IOException {\n",
                        "        final int i = Character.digit((char) b, 16);\n",
                        "        if (i == -1) {\n",
                        "            throw new IOException(\"Invalid quoted printable encoding: not a valid hex digit: \" + b);\n",
                        "        }\n",
                        "        return i;\n",
                        "    }\n"
