                        "                    final Option option =\n",
                        "                            Option.builder1(String.valueOf(opt))\n",
                        "                                    .hasArg1(type != null)\n",
                        "                                    .required1(required)\n",
                        "                                    .type(type)\n",
                        "                                    .build();\n",
                        "\n",
                        "                    options.addOption0(option);\n",
                        "                    required = false;\n",
                        "                    type = null;\n",
                        "                    opt = ' ';\n",
                        "                }\n",
                        "\n",
                        "                opt = ch;\n",
                        "            } else if (ch == '!') {\n",
                        "                required = true;\n",
                        "            } else {\n",
                        "                type = (Class<?>) getValueClass(ch);\n",
                        "            }\n",
                        "        }\n",
                        "\n",
