                    "translation": [
                        "    def _processParsedValue(self, value: typing.Any, formatter: Format) -> typing.Any:",
                        "         double_value = float(value)",
                        "         if double_value > 0:",
                        "             if double_value < float.fromhex(\"0x1.0p-126\"):  # Float.MIN_VALUE",
                        "                 return None",
                        "             if double_value > float.fromhex(\"0x1.fffffep+127\"):  # Float.MAX_VALUE",
                        "                 return None",
                        "         elif double_value < 0:",
                        "             pos_double = double_value * -1",
                        "             if pos_double < float.fromhex(\"0x1.0p-126\"):  # Float.MIN_VALUE",
                        "                 return None",
                        "             if pos_double > float.fromhex(\"0x1.fffffep+127\"):  # Float.MAX_VALUE",
                        "                 return None",
                        "         return float(double_value)"
                    ],
