                        "            return str;\n",
                        "        }\n",
                        "\n",
                        "        final StringBuilder sBuf = new StringBuilder();\n",
                        "        sBuf.append(str.charAt(0));\n",
                        "\n",
                        "        char last, current;\n",
                        "        last = '*';\n",
                        "\n",
                        "        for (int i = 0; i < str.length(); i++) {\n",
                        "\n",
                        "            current = getMappingCode(str.charAt(i));\n",
                        "            if (current == last) {\n",
                        "                continue;\n",
                        "            }\n",
                        "            if (current != 0) {\n",
                        "                sBuf.append(current);\n",
                        "            }\n",
                        "\n",
                        "            last = current;\n",
                        "        }\n",
                        "\n",
                        "        return sBuf.toString();\n",
                        "    }\n"
