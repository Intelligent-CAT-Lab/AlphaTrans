                        "                }\n",
                        "                StringBuilder buf = new StringBuilder(array.length * 8);\n",
                        "                for (int i = 0; i < array.length; i++) {\n",
                        "                    if (array[i] == null) {\n",
                        "                        buf.append(\"\\\\-\");\n",
                        "                    } else {\n",
                        "                        char ch = array[i].charValue();\n",
                        "                        if (ch == '\\\\') {\n",
                        "                            buf.append(\"\\\\\\\\\");\n",
                        "                        } else {\n",
                        "                            buf.append(ch);\n",
                        "                        }\n",
                        "                    }\n",
                        "                }\n",
                        "                return buf.toString();\n",
                        "            }\n"
