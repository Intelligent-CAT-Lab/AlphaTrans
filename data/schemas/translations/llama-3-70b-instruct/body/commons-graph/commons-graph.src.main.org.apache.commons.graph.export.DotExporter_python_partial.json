                    ],
                    "translation": [
                        "    def __printVertexOrEdgeProperties(self, properties: typing.Dict[str, typing.Any]) -> None:",
                        "         if not properties:",
                        "             return",
                        "         count_added_properties = 0",
                        "         self.__printWriter.write(\" [\")",
                        "         for property in properties.items():",
                        "             formatted_string = \"%s=\\\"%s\\\"\" if count_added_properties == len(properties) - 1 else \"%s=\\\"%s\\\" \"",
                        "             self.__printWriter.write(formatted_string % (property[0], property[1]))",
                        "             count_added_properties += 1",
                        "         self.__printWriter.write(\"];\\n\")"
                    ],
