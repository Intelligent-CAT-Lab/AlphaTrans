                    "translation": [
                        "    def __applyingSearch(self, handler: GraphVisitHandler[typing.Any, typing.Any, typing.Any, typing.Any], enqueue: bool) -> typing.Any:",
                        "         handler = Assertions.checkNotNull(handler, \"Graph visitor handler can not be null.\")",
                        "",
                        "         handler.discoverGraph(self.__graph)",
                        "",
                        "         vertex_list = deque() if enqueue else deque([(self.__source, self.__source)])",
                        "",
                        "         visited_vertices = set()",
                        "         visited_vertices.add(self.__source)",
                        "",
                        "         visiting_graph = True",
                        "",
                        "         while visiting_graph and vertex_list:",
                        "             pair = vertex_list.popleft() if enqueue else vertex_list.pop()",
                        "             v = pair[0]",
                        "             prev_head = pair[1]",
                        "             e = self.__graph.get_edge(prev_head, v) if prev_head != v else None",
                        "",
                        "             skip_vertex = False",
                        "",
                        "             if e is not None:",
                        "                 if v in visited_vertices:",
                        "                     skip_vertex = True",
                        "                 else:",
                        "                     state_after_edge_discovery = handler.discover_edge(prev_head, e, v)",
                        "                     if state_after_edge_discovery != VisitState.CONTINUE:",
                        "                         skip_vertex = True",
                        "                         if state_after_edge_discovery == VisitState.ABORT:",
                        "                             visiting_graph = False",
                        "                     if handler.finish_edge(prev_head, e, v) == VisitState.ABORT:",
                        "                         skip_vertex = True",
                        "                         visiting_graph = False",
                        "",
                        "             vertex_was_discovered = False",
                        "             if not skip_vertex:",
                        "                 visited_vertices.add(v)",
                        "                 state_after_vertex_discovery = handler.discover_vertex(v)",
                        "                 vertex_was_discovered = True",
                        "                 if state_after_vertex_discovery != VisitState.CONTINUE:",
                        "                     skip_vertex = True",
                        "                     if state_after_vertex_discovery == VisitState.ABORT:",
                        "                         visiting_graph = False",
                        "",
                        "             if not skip_vertex:",
                        "                 connected = self.__graph.get_outbound(v).iterator() if isinstance(self.__graph, DirectedGraph) else self.__graph.get_connected_vertices(v).iterator()",
                        "                 while connected.hasNext():",
                        "                     w = connected.next()",
                        "                     if w not in visited_vertices:",
                        "                         vertex_list.append((w, v)) if enqueue else vertex_list.appendleft((w, v))",
                        "",
                        "             if vertex_was_discovered and handler.finish_vertex(v) == VisitState.ABORT:",
                        "                 visiting_graph = False",
                        "",
                        "         handler.finish_graph(self.__graph)",
                        "",
                        "         return handler.on_completed()"
                    ],
