                    "translation": [
                        "    def __createCommandFile(self, cmd: CommandLine, env: typing.Dict[str, str]) -> pathlib.Path:",
                        "         path = pathlib.Path(tempfile.mktemp(suffix=\".TMP\", prefix=\"EXEC\"))",
                        "         script = path",
                        "         script.touch(exist_ok=True)",
                        "         with io.TextIOWrapper(io.BufferedWriter(path.open('w', encoding='utf-8')), encoding='utf-8', newline='') as writer:",
                        "             if env is not None:",
                        "                 for key, value in env.items():",
                        "                     writer.write(f\"${key} == \\\"{value}\\\"\")",
                        "                     writer.write(\"\\n\")",
                        "             command = cmd.getExecutable()",
                        "             if cmd.isFile():  # We assume it is a script file",
                        "                 parts = StringUtils.split(command, \"/\")",
                        "                 writer.write(f\"${parts[0]}:[{parts[1]}\")",
                        "                 for i in range(2, len(parts) - 1):",
                        "                     writer.write(f\".{parts[i]}\")",
                        "                 writer.write(f\"][{parts[-1]}\")",
                        "             else:",
                        "                 writer.write(f\"${command}\")",
                        "             for arg in cmd.getArguments():",
                        "                 writer.write(f\" -{arg}\\n\")",
                        "             writer.write(\"\\n\")",
                        "         return script"
                    ],
