                        "    public long skip(final long n) throws IOException {\n",
                        "        if (n < 0) {\n",
                        "            throw new IllegalArgumentException(\"Negative skip length: \" + n);\n",
                        "        }\n",
                        "\n",
                        "        final byte[] b = new byte[512];\n",
                        "        long todo = n;\n",
                        "\n",
                        "        while (todo > 0) {\n",
                        "            int len = (int) Math.min(b.length, todo);\n",
                        "            len = this.read1(b, 0, len);\n",
                        "            if (len == EOF) {\n",
                        "                break;\n",
                        "            }\n",
                        "            todo -= len;\n",
                        "        }\n",
                        "\n",
                        "        return n - todo;\n",
                        "    }\n"
                    ],
