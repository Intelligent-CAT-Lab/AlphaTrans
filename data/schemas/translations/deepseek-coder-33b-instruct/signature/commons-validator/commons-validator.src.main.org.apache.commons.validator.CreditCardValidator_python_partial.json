                        "        long sum = 0;\n",
                        "        for (int count = 0; count < digits; count++) {\n",
                        "            int digit = 0;\n",
                        "            try {\n",
                        "                digit = Integer.parseInt(cardNumber.charAt(count) + \"\");\n",
                        "            } catch (NumberFormatException e) {\n",
                        "                return false;\n",
                        "            }\n",
                        "\n",
                        "            if (((count & 1) ^ oddOrEven) == 0) { // not\n",
                        "                digit *= 2;\n",
                        "                if (digit > 9) {\n",
                        "                    digit -= 9;\n",
                        "                }\n",
                        "            }\n",
                        "            sum += digit;\n",
                        "        }\n",
                        "\n",
                        "        return (sum == 0) ? false : (sum % 10 == 0);\n",
