                        "    public int compare(V left, V right) {\n",
                        "        if (!hasWeight(left) && !hasWeight(right)) {\n",
                        "            return 0;\n",
                        "        } else if (!hasWeight(left)) {\n",
                        "            return 1;\n",
                        "        } else if (!hasWeight(right)) {\n",
                        "            return -1;\n",
                        "        }\n",
                        "        return weightOperations.compare(getWeight(left), getWeight(right));\n",
                        "    }\n"
