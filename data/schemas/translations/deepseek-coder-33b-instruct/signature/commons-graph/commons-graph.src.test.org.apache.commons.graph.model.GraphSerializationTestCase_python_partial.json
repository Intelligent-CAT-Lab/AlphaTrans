                        "\n",
                        "                addEdge(new BaseLabeledWeightedEdge<Double>(\"a -> c\", 1D)).from(a).to(c);\n",
                        "                addEdge(new BaseLabeledWeightedEdge<Double>(\"c -> d\", 1D)).from(c).to(d);\n",
                        "                addEdge(new BaseLabeledWeightedEdge<Double>(\"d -> b\", 1D)).from(d).to(b);\n",
