                        "        public static long fastinverseDelta(long[] data, int start, int length,\n",
                        "                int init) {\n",
                        "                data[start] += init;\n",
                        "                int sz0 = length / 4 * 4;\n",
                        "                int i = 1;\n",
                        "                if (sz0 >= 4) {\n",
                        "                \tlong a = data[start];\n",
                        "                        for (; i < sz0 - 4; i += 4) {\n",
                        "                                a = data[start + i] += a;\n",
                        "                                a = data[start + i + 1] += a;\n",
                        "                                a = data[start + i + 2] += a;\n",
                        "                                a = data[start + i + 3] += a;\n",
                        "                        }\n",
                        "                }\n",
                        "\n",
                        "                for (; i != length; ++i) {\n",
                        "                        data[start + i] += data[start + i - 1];\n",
                        "                }\n",
                        "                return data[start + length - 1];\n",
                        "        }\n"
