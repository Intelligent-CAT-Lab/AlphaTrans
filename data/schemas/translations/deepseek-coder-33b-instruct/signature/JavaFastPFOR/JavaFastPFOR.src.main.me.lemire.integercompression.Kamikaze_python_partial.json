                    "body": [
                        "    public void headlessUncompress(int[] in, IntWrapper inpos, int inlength, int[] out,\n",
                        "            IntWrapper outpos, int num) {\n",
                        "        num = Util.greatestMultiple(num, BLOCK_SIZE);\n",
                        "        if (num > 0) {\n",
                        "            int d = PForDelta.decompressOneBlock(out, in, num);\n",
                        "            inpos.add(d / 32);\n",
                        "            outpos.add(num);\n",
                        "        }\n",
                        "    }\n"
                    ],
