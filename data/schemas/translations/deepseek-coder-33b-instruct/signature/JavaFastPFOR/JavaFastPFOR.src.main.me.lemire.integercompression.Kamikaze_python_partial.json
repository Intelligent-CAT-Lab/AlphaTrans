                        "    public void headlessCompress(int[] in, IntWrapper inpos, int inlength, int[] out,\n",
                        "            IntWrapper outpos) {\n",
                        "        inlength = Util.greatestMultiple(inlength, BLOCK_SIZE);\n",
                        "        if (inlength > 0) {\n",
                        "            int[] out2 = PForDelta.compressOneBlockOpt(in, inlength);\n",
                        "            inpos.add(inlength);\n",
