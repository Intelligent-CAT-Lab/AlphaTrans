                        "        static long[] negate(long[] x, long Max) {\n",
                        "        \tint newLength = saturatedCast(Max - x.length);\n",
                        "        \tlong[] ans = new long[newLength];\n",
                        "                int i = 0;\n",
                        "                int c = 0;\n",
                        "                for (int j = 0; j < x.length; ++j) {\n",
                        "                \tlong v = x[j];\n",
                        "                        for (; i < v; ++i)\n",
                        "                                ans[c++] = i;\n",
                        "                        ++i;\n",
                        "                }\n",
                        "                while (c < ans.length)\n",
                        "                        ans[c++] = i++;\n",
                        "                return ans;\n",
                        "        }\n"
