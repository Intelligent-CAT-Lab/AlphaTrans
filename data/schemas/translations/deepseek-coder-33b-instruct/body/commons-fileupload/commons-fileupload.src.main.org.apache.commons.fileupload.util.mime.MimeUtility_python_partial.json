                        "                    startWhiteSpace = -1;\n",
                        "                }\n",
                        "                previousTokenEncoded = false;\n",
                        "                decodedText.append(word);\n",
                        "            }\n",
                        "        }\n",
                        "\n",
                        "        return decodedText.toString();\n",
                        "    }\n"
