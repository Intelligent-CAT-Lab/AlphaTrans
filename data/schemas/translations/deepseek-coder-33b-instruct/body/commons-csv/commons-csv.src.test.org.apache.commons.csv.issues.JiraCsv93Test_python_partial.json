                        "        every(\n",
                        "                CSVFormat.DEFAULT\n",
                        "                        .builder()\n",
                        "                        .setNullString(\"NULL\")\n",
                        "                        .setQuoteMode(QuoteMode.NON_NUMERIC)\n",
