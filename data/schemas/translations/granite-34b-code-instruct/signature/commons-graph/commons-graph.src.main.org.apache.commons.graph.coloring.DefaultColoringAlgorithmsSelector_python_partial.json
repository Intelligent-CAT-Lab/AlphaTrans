                        "\n",
                        "        for (V abj : g.getConnectedVertices(currentVertex)) {\n",
                        "            C adjColor = coloredVertices.getColor(abj);\n",
                        "            if (adjColor != null && nextVertecColor.equals(adjColor)) {\n",
                        "                return true;\n",
                        "            }\n",
                        "        }\n",
                        "        return false;\n",
                        "    }\n"
