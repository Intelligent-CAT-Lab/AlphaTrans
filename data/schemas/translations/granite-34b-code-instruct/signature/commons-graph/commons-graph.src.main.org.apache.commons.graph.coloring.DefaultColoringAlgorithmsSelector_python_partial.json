                        "        V nextVertex = verticesList.get(next);\n",
                        "        for (C color : colors) {\n",
                        "            coloredVertices.addColor(nextVertex, color);\n",
                        "            boolean isDone = backtraking(next, verticesList, coloredVertices);\n",
                        "            if (isDone) {\n",
                        "                return true;\n",
                        "            }\n",
                        "        }\n",
