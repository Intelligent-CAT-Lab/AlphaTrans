                        "            throws IOException {\n",
                        "        MoneyFormatter fmt =\n",
                        "                (money.isZero() ? whenZero : money.isPositive() ? whenPositive : whenNegative);\n",
                        "        fmt.getPrinterParser().print(context, appendable, money);\n",
                        "    }\n"
