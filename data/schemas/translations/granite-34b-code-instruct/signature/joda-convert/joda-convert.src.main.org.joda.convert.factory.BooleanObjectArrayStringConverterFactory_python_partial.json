                "78-97:convertFromString": {
                    "start": 78,
                    "end": 97,
                    "body": [
                        "            public Boolean[] convertFromString(Class<? extends Boolean[]> cls, String str) {\n",
                        "                if (str.length() == 0) {\n",
                        "                    return EMPTY;\n",
                        "                }\n",
                        "                Boolean[] array = new Boolean[str.length()];\n",
                        "                for (int i = 0; i < array.length; i++) {\n",
                        "                    char ch = str.charAt(i);\n",
                        "                    if (ch == 'T') {\n",
                        "                        array[i] = Boolean.TRUE;\n",
                        "                    } else if (ch == 'F') {\n",
                        "                        array[i] = Boolean.FALSE;\n",
                        "                    } else if (ch == '-') {\n",
                        "                        array[i] = null;\n",
                        "                    } else {\n",
                        "                        throw new IllegalArgumentException(\n",
                        "                                \"Invalid Boolean[] string, must consist only of 'T', 'F' and '-'\");\n",
                        "                    }\n",
                        "                }\n",
                        "                return array;\n",
                        "            }\n"
                    ],
                    "is_constructor": false,
                    "annotations": [
