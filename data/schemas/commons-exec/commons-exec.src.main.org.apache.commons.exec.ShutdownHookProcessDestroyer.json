                    "body": [
                        "    public void run() {\n",
                        "        synchronized (processes) {\n",
                        "            running = true;\n",
                        "            processes.forEach(process -> {\n",
                        "                try {\n",
                        "                    process.destroy();\n",
                        "                } catch (final Throwable t) {\n",
                        "                    System.err.println(\"Unable to terminate process during process shutdown\");\n",
                        "                }\n",
                        "            });\n",
                        "        }\n",
