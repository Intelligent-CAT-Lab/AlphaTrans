                "91-97:addShutdownHook": {
                    "start": 91,
                    "end": 97,
                    "body": [
                        "    private void addShutdownHook() {\n",
                        "        if (!running) {\n",
                        "            destroyProcessThread = new ProcessDestroyerThread();\n",
                        "            Runtime.getRuntime().addShutdownHook(destroyProcessThread);\n",
                        "            added = true;\n",
                        "        }\n",
                        "    }\n"
                    ],
