                        "    public void testLanguageGuessing() {\n",
                        "        final Languages.LanguageSet guesses = this.lang.guessLanguages(this.name);\n",
                        "\n",
                        "        assertTrue(\n",
                        "                \"language predicted for name '\"\n",
                        "                        + this.name\n",
                        "                        + \"' is wrong: \"\n",
                        "                        + guesses\n",
                        "                        + \" should contain '\"\n",
                        "                        + this.language\n",
                        "                        + \"'\",\n",
                        "                guesses.contains(this.language));\n",
                        "    }\n"
