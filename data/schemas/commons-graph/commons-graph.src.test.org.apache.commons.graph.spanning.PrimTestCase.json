                        "    public void testNullMonoid() {\n",
                        "        UndirectedMutableGraph<BaseLabeledVertex, BaseLabeledWeightedEdge<Double>> input = null;\n",
                        "        BaseLabeledVertex a = null;\n",
                        "        try {\n",
                        "            input =\n",
                        "                    new UndirectedMutableGraph<\n",
