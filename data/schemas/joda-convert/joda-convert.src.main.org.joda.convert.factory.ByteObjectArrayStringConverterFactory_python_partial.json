                        "                }\n",
                        "                StringBuilder buf = new StringBuilder(array.length);\n",
                        "                for (int i = 0; i < array.length; i++) {\n",
                        "                    if (array[i] == null) {\n",
                        "                        buf.append('-').append('-');\n",
                        "                    } else {\n",
                        "                        int b = array[i].byteValue();\n",
                        "                        buf.append(HEX.charAt((b & 0xF0) >>> 4)).append(HEX.charAt(b & 0x0F));\n",
                        "                    }\n",
                        "                }\n",
                        "                return buf.toString();\n",
                        "            }\n"
