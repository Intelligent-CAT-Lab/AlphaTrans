                    "start": 41,
                    "end": 49,
                    "body": [
                        "    public StringConverter<?> findConverter(Class<?> cls) {\n",
                        "        Class<?> sup = cls.getSuperclass();\n",
                        "        if (sup == Enum.class) {\n",
                        "            return new EnumStringConverter(cls);\n",
                        "        } else if (sup != null && sup.getSuperclass() == Enum.class) {\n",
                        "            return new EnumStringConverter(sup);\n",
                        "        }\n",
                        "        return null;\n",
                        "    }\n"
                    ],
