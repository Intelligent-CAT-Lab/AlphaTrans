                        "            assertEquals(\"length is not match\", outpos.get(), data[k].length);\n",
                        "            long[] bufferCutout = Arrays.copyOf(buffer, outpos.get());\n",
                        "            assertArrayEquals(\"failed to reconstruct original data\", data[k],\n",
                        "                    bufferCutout);\n",
